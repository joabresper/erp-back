// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String?   
  address   String?
  deletedAt DateTime?

  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roleId    String

  priceChanges PriceChange[]
  sales Sale[]
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  level     Int      @default(1) 

  users User[]
  permissions Permission[]
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?

  roles Role[]
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  type        ProductType @default(GENERIC)
  unit        UnitMeasure @default(UNIT)
  isSalable   Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceChanges PriceChange[]
  saleItems SaleItem[]
}

model PriceChange {
  id        String   @id @default(uuid())
  oldPrice  Decimal  @db.Decimal(10, 2)
  newPrice  Decimal  @db.Decimal(10, 2)
  date      DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  postalCode String?
  taxId     String?  @unique
  taxCondition String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]
}

model SaleItem {
  id            String   @id @default(uuid())
  productName   String
  productSku    String
  quantity      Decimal  @db.Decimal(5, 2)
  unitPrice     Decimal  @db.Decimal(10, 2) // Precio unitario al momento de la venta
  discountAmount Decimal  @db.Decimal(10, 2)
  subtotalAmount Decimal  @db.Decimal(10, 2)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  saleId String
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Sale {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  totalAmount     Decimal  @db.Decimal(10, 2)
  totalDiscountAmount  Decimal  @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  invoiceNumber   String?
  invoiceDate     DateTime
  invoiceType     InvoiceType @default(TICKET)

  items SaleItem[]

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model InvoiceSequence {
  id          String        @id @default(uuid())
  type        InvoiceType   @unique
  prefix      Int           @default(1) //Punto de venta
  lastNumber  Int           @default(0)
  updatedAt   DateTime      @updatedAt

  @@unique([type, prefix])
}

// ENUMS
enum ProductType {
  RAW_MATERIAL
  FINISHED_GOOD
  RESALE
  GENERIC
}

enum UnitMeasure {
  KILOGRAM
  LITER
  UNIT
}

enum PaymentStatus {
  PENDING        // Pendiente de pago
  PARTIALLY_PAID // Pago parcial (señas)
  PAID           // Totalmente pagado
  CANCELED      // Venta anulada (no se cobra)
  REFUNDED       // Devuelta (se cobró y se devolvió la plata)
}

enum InvoiceType {
  A
  B
  C
  TICKET
  CREDIT_NOTE
}

enum PaymentMethod {
  CASH            // Efectivo
  DEBIT_CARD      // Débito
  CREDIT_CARD     // Crédito
  TRANSFER        // Transferencia bancaria
  ACCOUNT_CREDIT  // "Cuenta Corriente" (fiado)
}